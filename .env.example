DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
BASE_URL=http://localhost:5000
SESSION_SECRET=super_secret_session_key
# Comma-separated accounts allowed to open /admin. Email comparison is case-insensitive.
ADMIN_EMAILS=owner@example.com,operations@example.com
STRIPE_SECRET_KEY=sk_test_123
STRIPE_WEBHOOK_SECRET=whsec_123
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_123
STRIPE_PRO_PRICE_ID=price_pro
STRIPE_STARTER_KIT_PRICE_ID=price_starter
STRIPE_INTERVIEW_PREP_PRICE_ID=price_interview
STRIPE_BUNDLE_PRICE_ID=price_bundle
STRIPE_GMP_AUDIT_KIT_PRICE_ID=price_gmp_audit_kit
STRIPE_SCOPE_DIAGNOSTIC_PRICE_ID=price_scope_diagnostic

# Resend email (https://resend.com - free 3000 emails/month)
RESEND_API_KEY=re_123abc
EMAIL_FROM=Life Science Atlas <no-reply@yourdomain.com>
# Comma-separated inboxes receiving new commercial-request alerts. Falls back to ADMIN_EMAILS.
COMMERCIAL_NOTIFICATION_EMAILS=owner@yourdomain.com

# Protects /api/cron/* lifecycle jobs.
CRON_SECRET=replace_with_a_long_random_secret

# Product download links (Google Drive or similar)
DOWNLOAD_GMP_AUDIT_KIT=https://drive.google.com/your-gmp-audit-kit-link
DOWNLOAD_STARTER_KIT=https://drive.google.com/your-starter-kit-link
DOWNLOAD_INTERVIEW_PREP=https://drive.google.com/your-interview-prep-link
DOWNLOAD_BUNDLE=https://drive.google.com/your-bundle-link
DOWNLOAD_GMP_CHECKLIST=https://drive.google.com/your-gmp-checklist-pdf

# PostHog Analytics
VITE_POSTHOG_KEY=phc_your_posthog_key_here

# Public site origin (build-time). Set to the custom domain at launch + redeploy.
VITE_SITE_URL=https://lifescienceatlas.com
